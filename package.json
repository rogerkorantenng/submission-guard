{
  "name": "submission-guard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "main.tsx",
  "engines": {
    "node": ">=22.2.0"
  },
  "scripts": {
    "dev:client": "vite",
    "build:client": "vite build --config vite.config.ts",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devvit/public-api": "0.12.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "license": "Apache-2.0"
}
